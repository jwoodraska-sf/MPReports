  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Tablix Name="VolunteerByWeekendMatrix">
            <TablixCorner>
              <TablixCornerRows>
                <TablixCornerRow>
                  <TablixCornerCell>
                    <CellContents>
                      <Textbox Name="CornerVolunteer">
                        <CanGrow>true</CanGrow>
                        <KeepTogether>true</KeepTogether>
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>Volunteer</Value>
                                <Style>
                                  <FontWeight>Bold</FontWeight>
                                </Style>
                              </TextRun>
                            </TextRuns>
                            <Style>
                              <TextAlign>Center</TextAlign>
                            </Style>
                          </Paragraph>
                        </Paragraphs>
                        <rd:DefaultName>CornerVolunteer</rd:DefaultName>
                        <Style>
                          <Border>
                            <Style>Solid</Style>
                          </Border>
                          <BackgroundColor>#d3d3d3</BackgroundColor>
                          <VerticalAlign>Middle</VerticalAlign>
                          <PaddingLeft>3pt</PaddingLeft>
                          <PaddingRight>3pt</PaddingRight>
                          <PaddingTop>3pt</PaddingTop>
                          <PaddingBottom>3pt</PaddingBottom>
                        </Style>
                      </Textbox>
                    </CellContents>
                  </TablixCornerCell>
                </TablixCornerRow>
              </TablixCornerRows>
            </TablixCorner>
            <TablixBody>
              <TablixColumns>
                <TablixColumn>
                  <Width>1.5in</Width>
                </TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.5in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ServiceTimeCell">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Join(
    LookupSet(
        First(Fields!Volunteer_Name.Value, "VolunteerNameGroup") &amp; "|" &amp; Fields!Weekend_Group.Value,
        Fields!Volunteer_Name.Value &amp; "|" &amp; Fields!Weekend_Group.Value,
        Format(Fields!Event_Start_Date_Sort.Value, "h:mm tt") &amp; " - " &amp; Fields!Volunteer_Role.Value,
        "DataSet1"
    ),
    vbCrLf
)</Value>
                                  <Style>
                                    <FontSize>8pt</FontSize>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>ServiceTimeCell</rd:DefaultName>
                          <Style>
                            <Border>
                              <Style>Solid</Style>
                            </Border>
                            <BackgroundColor>=IIF(InStr(Join(LookupSet(First(Fields!Volunteer_Name.Value, "VolunteerNameGroup") &amp; "|" &amp; Fields!Weekend_Group.Value, Fields!Volunteer_Name.Value &amp; "|" &amp; Fields!Weekend_Group.Value, Fields!Volunteer_Role.Value, "DataSet1"), ","), "YOUTH MASS") &gt; 0, "Yellow", "White")</BackgroundColor>
                            <VerticalAlign>Top</VerticalAlign>
                            <PaddingLeft>3pt</PaddingLeft>
                            <PaddingRight>3pt</PaddingRight>
                            <PaddingTop>3pt</PaddingTop>
                            <PaddingBottom>3pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember>
                  <Group Name="WeekendGroup">
                    <GroupExpressions>
                      <GroupExpression>=Fields!Weekend_Group.Value</GroupExpression>
                    </GroupExpressions>
                  </Group>
                  <SortExpressions>
                    <SortExpression>
                      <Value>=Fields!Weekend_Group.Value</Value>
                    </SortExpression>
                  </SortExpressions>
                  <TablixHeader>
                    <Size>0.5in</Size>
                    <CellContents>
                      <Textbox Name="WeekendHeader">
                        <CanGrow>true</CanGrow>
                        <KeepTogether>true</KeepTogether>
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>=Format(First(Fields!Weekend_Group.Value, "WeekendGroup"), "MMMM d") &amp; "-" &amp; Format(DateAdd("d", 1, First(Fields!Weekend_Group.Value, "WeekendGroup")), "d")</Value>
                                <Style>
                                  <FontSize>9pt</FontSize>
                                  <FontWeight>Bold</FontWeight>
                                </Style>
                              </TextRun>
                            </TextRuns>
                            <Style>
                              <TextAlign>Center</TextAlign>
                            </Style>
                          </Paragraph>
                        </Paragraphs>
                        <rd:DefaultName>WeekendHeader</rd:DefaultName>
                        <Style>
                          <Border>
                            <Style>Solid</Style>
                          </Border>
                          <BackgroundColor>#d3d3d3</BackgroundColor>
                          <VerticalAlign>Middle</VerticalAlign>
                          <PaddingLeft>3pt</PaddingLeft>
                          <PaddingRight>3pt</PaddingRight>
                          <PaddingTop>3pt</PaddingTop>
                          <PaddingBottom>3pt</PaddingBottom>
                        </Style>
                      </Textbox>
                    </CellContents>
                  </TablixHeader>
                </TablixMember>
              </TablixMembers>
            </TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember>
                  <Group Name="VolunteerNameGroup">
                    <GroupExpressions>
                      <GroupExpression>=Fields!Volunteer_Name.Value</GroupExpression>
                    </GroupExpressions>
                  </Group>
                  <SortExpressions>
                    <SortExpression>
                      <Value>=Fields!Volunteer_ByLastName.Value</Value>
                    </SortExpression>
                  </SortExpressions>
                  <TablixHeader>
                    <Size>1.5in</Size>
                    <CellContents>
                      <Textbox Name="VolunteerNameHeader">
                        <CanGrow>true</CanGrow>
                        <KeepTogether>true</KeepTogether>
                        <Paragraphs>
                          <Paragraph>
                            <TextRuns>
                              <TextRun>
                                <Value>=First(Fields!Volunteer_ByLastName.Value, "VolunteerNameGroup")</Value>
                                <Style>
                                  <FontSize>9pt</FontSize>
                                </Style>
                              </TextRun>
                            </TextRuns>
                            <Style>
                              <TextAlign>Left</TextAlign>
                            </Style>
                          </Paragraph>
                        </Paragraphs>
                        <rd:DefaultName>VolunteerNameHeader</rd:DefaultName>
                        <Style>
                          <Border>
                            <Style>Solid</Style>
                          </Border>
                          <BackgroundColor>White</BackgroundColor>
                          <VerticalAlign>Middle</VerticalAlign>
                          <PaddingLeft>5pt</PaddingLeft>
                          <PaddingRight>3pt</PaddingRight>
                          <PaddingTop>3pt</PaddingTop>
                          <PaddingBottom>3pt</PaddingBottom>
                        </Style>
                      </Textbox>
                    </CellContents>
                  </TablixHeader>
                  <TablixMembers>
                    <TablixMember />
                  </TablixMembers>
                </TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <RepeatColumnHeaders>true</RepeatColumnHeaders>
            <RepeatRowHeaders>true</RepeatRowHeaders>
            <DataSetName>DataSet1</DataSetName>
            <Top>0.5in</Top>
