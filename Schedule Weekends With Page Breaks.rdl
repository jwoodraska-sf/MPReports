                    <TablixCell>
                      <CellContents>
                        <Textbox Name="VolunteerData">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Join(
    LookupSet(
        First(Fields!Weekend_Group.Value, "WeekendGroup") &amp; "|" &amp; First(Fields!Volunteer_Role.Value, "VolunteerRoleGroup") &amp; "|" &amp; Fields!Group_Name.Value,
        Fields!Weekend_Group.Value &amp; "|" &amp; Fields!Volunteer_Role.Value &amp; "|" &amp; Fields!Group_Name.Value,
        IIF(IsNothing(Fields!Volunteer_Name.Value) OR Fields!Volunteer_Name.Value = "", 
            IIF(Fields!Unfilled_Roles.Value &gt; 0, "Need " &amp; Fields!Unfilled_Roles.Value, ""), 
            Fields!Volunteer_Name.Value),
        "DataSet1"
    ),
    vbCrLf )</Value>
                                  <Style>
                                    <FontSize>7pt</FontSize>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>VolunteerData</rd:DefaultName>
                          <Style>
                            <Border>
                              <Color>LightGrey</Color>
                              <Style>Solid</Style>
                            </Border>
                            <BackgroundColor>=IIF(First(Fields!Volunteer_Role.Value, "VolunteerRoleGroup") = "YOUTH MASS", "Yellow", "White")</BackgroundColor>
                            <VerticalAlign>Top</VerticalAlign>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
